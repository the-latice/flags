{
  "name": "@latice/flags-react",
  "version": "0.1.2",
  "description": "Country flag components for React. Lightweight, tree-shakable, SSR-ready.",
  "keywords": [
    "latice",
    "flag",
    "flags",
    "country",
    "svg",
    "react",
    "next",
    "iso-3166",
    "ssr",
    "components"
  ],
  "type": "module",
  "license": "ISC",
  "homepage": "https://github.com/the-latice/flags",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-latice/flags.git",
    "directory": "packages/react"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./static": {
      "types": "./dist/static.d.ts",
      "import": "./dist/static.es.js"
    }
  },
  "scripts": {
    "gen": "tsx ../core/scripts/generate-flags.ts react",
    "build": "pnpm run gen && vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@latice/flags-core": "workspace:*",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "react": "^19.0.0",
    "tsx": "^4.22.4"
  }
}
